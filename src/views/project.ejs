<%- include('partials/header') %>

    <main>

        <h1><%= title %></h1>

        <p><strong>Date:</strong>
            <%= new Date(project.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
        </p>

        <p><strong>Location:</strong> <%= project.location %></p>

        <p><strong>Partner Organization:</strong>
            <a href="/organizations/<%= project.organization_id %>">
                <%= project.organization_name %>
            </a>
        </p>

        <h3>Description</h3>
        <p><%= project.description %></p>

        <!-- Category Tags -->
        <% if (categories && categories.length > 0) { %>
            <h3>Categories</h3>
            <ul class="list-cards chips">
                <% categories.forEach(cat => { %>
                    <li>
                        <a href="/categories/<%= cat.category_id %>">
                            <%= cat.category_name %>
                        </a>
                    </li>
                <% }); %>
            </ul>
        <% } %>

        <p>
            <a href="/edit-project/<%= project.project_id %>">✏️ Edit Project</a>
            &nbsp;|&nbsp;
            <!-- ADDED: link to assign categories — required by rubric item 3 -->
            <a href="/assign-categories/<%= project.project_id %>">🏷️ Edit Categories</a>
        </p>

    </main>

<%- include('partials/footer') %>
